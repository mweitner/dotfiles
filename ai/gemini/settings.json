{
  "general": {
    "autoAccept": true,
    "theme": "GitHub"
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "tools": {
    "core": [
      "ReadFileTool",
      "GlobTool",
      "SearchText",
      "WriteFileTool",
      "GoogleSearch",
      "WebFetchTool",
      "ShellTool"
    ],
    "excludeTools": [
      "ShellTool(rm -rf)",
      "ShellTool(sudo)",
      "ShellTool(chmod -R)",
      "ShellTool(curl | bash)",
      "ShellTool(npm install -g)"
    ]
  }
}
