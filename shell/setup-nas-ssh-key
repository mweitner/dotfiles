#!/usr/bin/env bash

# Setup SSH key-based authentication for UGREEN NAS
# Generates ed25519 key and adds it to NAS authorized_keys
# Usage: setup-nas-ssh-key [--host ugreen-nas|ugreen-nas-home] [--password PASSWORD]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES="${DOTFILES:-$(dirname "$SCRIPT_DIR")}"

NAS_HOST="${NAS_HOST:-ugreen-nas}"
NAS_USER="michael"
KEY_PATH="${HOME}/.ssh/id_ed25519_ugreen_nas"
KEY_NAME="id_ed25519_ugreen_nas"

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      NAS_HOST="$2"
      shift 2
      ;;
    --password)
      NAS_PASSWORD="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Usage: setup-nas-ssh-key [--host ugreen-nas|ugreen-nas-home] [--password PASSWORD]"
      exit 1
      ;;
  esac
done

# Resolve hostname to IP
case "$NAS_HOST" in
  ugreen-nas)
    NAS_IP="192.168.3.91"
    ;;
  ugreen-nas-home)
    NAS_IP="192.168.1.110"
    ;;
  *)
    NAS_IP="$NAS_HOST"
    ;;
esac

echo "=== UGREEN NAS SSH Key Setup ==="
echo "Target: $NAS_HOST ($NAS_IP)"
echo ""

# Step 1: Generate SSH key if needed
if [[ ! -f "$KEY_PATH" ]]; then
  echo "📝 Generating ed25519 SSH key at $KEY_PATH..."
  ssh-keygen -t ed25519 -f "$KEY_PATH" -N "" -C "ugreen-nas-git" >/dev/null 2>&1
  chmod 600 "$KEY_PATH"
  chmod 644 "$KEY_PATH.pub"
  echo "✓ SSH key generated"
else
  echo "✓ SSH key already exists at $KEY_PATH"
fi

echo ""

# Step 2: Add public key to NAS authorized_keys
echo "📤 Adding public key to NAS authorized_keys..."

PUBLIC_KEY=$(cat "$KEY_PATH.pub")

# Remote script passed to 'bash -s -- "$PUBLIC_KEY"' on the NAS.
# Uses sudo to create the home dir if missing (UGREEN admin users have sudo),
# then installs the key at the passwd-defined home path that sshd expects.
read -r -d '' REMOTE_SCRIPT << 'ENDRS' || true
PUB_KEY="$1"
UNAME=$(id -un)
UHOME=$(getent passwd "$UNAME" | cut -d: -f6)
if [ ! -d "$UHOME" ]; then
  sudo mkdir -p "$UHOME" && sudo chown "$UNAME:" "$UHOME" || {
    echo "ERROR: cannot create $UHOME - run manually: sudo mkdir -p $UHOME && sudo chown $UNAME: $UHOME" >&2
    exit 1
  }
fi
mkdir -p "$UHOME/.ssh"
grep -qxF "$PUB_KEY" "$UHOME/.ssh/authorized_keys" 2>/dev/null \
  || printf '%s\n' "$PUB_KEY" >> "$UHOME/.ssh/authorized_keys"
chmod 700 "$UHOME/.ssh"
chmod 600 "$UHOME/.ssh/authorized_keys"
ENDRS

# Check if we can connect via ssh-agent first
if sshpass -V >/dev/null 2>&1 || ssh-keyscan -t ed25519 "$NAS_IP" >/dev/null 2>&1 2>&1; then
  # Try to use sshpass if password is provided
  if [[ -v NAS_PASSWORD ]]; then
    echo "Adding key using password authentication..."
    echo "$REMOTE_SCRIPT" | sshpass -p "$NAS_PASSWORD" \
      ssh -o PreferredAuthentications=password,keyboard-interactive "$NAS_HOST" bash -s -- "$PUBLIC_KEY" 2>/dev/null || {
      echo "❌ Failed to add key via password" >&2
      exit 1
    }
  else
    # No --password flag: connect interactively (user types NAS password at prompt)
    echo ""
    echo "⚠️  Interactive SSH connection required."
    echo "You will be prompted for the NAS password."
    echo ""
    echo "Connecting to $NAS_HOST..."
    echo "$REMOTE_SCRIPT" | \
      ssh -o PreferredAuthentications=password,keyboard-interactive "$NAS_HOST" bash -s -- "$PUBLIC_KEY" || {
      echo "❌ Failed to add key" >&2
      exit 1
    }
  fi
else
  # No direct connection; show manual instructions
  echo ""
  echo "⚠️  Cannot auto-connect to NAS. Manual setup required:"
  echo ""
  echo "1. SSH into NAS: ssh $NAS_HOST"
  echo "2. Create your home dir (requires sudo, which UGREEN admin users have):"
  echo "   sudo mkdir -p /home/michael && sudo chown michael: /home/michael"
  echo "3. Add the public key:"
  echo "   mkdir -p ~/.ssh && printf '%s\\n' '$PUBLIC_KEY' >> ~/.ssh/authorized_keys && chmod 700 ~/.ssh && chmod 600 ~/.ssh/authorized_keys"
  echo ""
  read -p "Done? (y/n) " -n 1 -r
  echo
  [[ $REPLY =~ ^[Yy]$ ]] || exit 1
fi

echo "✓ Public key added to NAS"
echo ""

# Step 3: Test SSH connection
echo "🧪 Testing SSH connection to $NAS_HOST..."
if ssh -o ConnectTimeout=5 "$NAS_HOST" "echo 'SSH connection successful'" >/dev/null 2>&1; then
  echo "✓ SSH connection verified"
else
  echo "❌ SSH connection failed" >&2
  exit 1
fi

echo ""
echo "=== Setup Complete ==="
echo "You can now use:"
echo "  ssh $NAS_HOST"
echo "  ssh-copy-id -i $KEY_PATH $NAS_HOST"
echo ""
echo "For git operations, use:"
echo "  git clone ssh://$NAS_HOST/volume1/data/repos/PROJECT.git"
echo "  git push origin main"
echo ""
