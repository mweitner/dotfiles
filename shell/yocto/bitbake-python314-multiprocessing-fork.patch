diff --git a/bitbake/bin/bitbake b/bitbake/bin/bitbake
index f494eaa132..379d826034 100755
--- a/bitbake/bin/bitbake
+++ b/bitbake/bin/bitbake
@@ -15,6 +15,16 @@ import sys
 import warnings
 warnings.simplefilter("default")
 
+# Python 3.14+ changed the default multiprocessing start method on Linux from
+# 'fork' to 'forkserver'.  BitBake uses nested functions and lambdas as process
+# targets, which are not picklable and break under forkserver/spawn.  Force
+# 'fork' (the previous default) before any BitBake module is imported so the
+# setting is inherited by every subprocess spawned by BitBake.
+if sys.platform.startswith('linux'):
+    import multiprocessing
+    if multiprocessing.get_start_method(allow_none=True) != 'fork':
+        multiprocessing.set_start_method('fork', force=True)
+
 sys.path.insert(0, os.path.join(os.path.dirname(os.path.dirname(__file__)),
                                 'lib'))
 try:
