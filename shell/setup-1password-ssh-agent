#!/usr/bin/env bash
set -euo pipefail

# Configure global SSH IdentityAgent to use 1Password agent socket.
# Idempotent: managed block is replaced on re-run.

SSH_DIR="${HOME}/.ssh"
SSH_CONFIG="${SSH_DIR}/config"
START_MARK="# >>> dotfiles 1password ssh agent >>>"
END_MARK="# <<< dotfiles 1password ssh agent <<<"

mkdir -p "${SSH_DIR}"
chmod 700 "${SSH_DIR}"

if [[ -f "${SSH_CONFIG}" ]]; then
  tmp_file="$(mktemp)"
  awk -v start="${START_MARK}" -v end="${END_MARK}" '
    $0 == start { drop=1; next }
    $0 == end { drop=0; next }
    drop != 1 { print }
  ' "${SSH_CONFIG}" > "${tmp_file}"
  mv "${tmp_file}" "${SSH_CONFIG}"
fi

cat >> "${SSH_CONFIG}" <<'EOF'
# >>> dotfiles 1password ssh agent >>>
Host *
  IdentityAgent ~/.1password/agent.sock
# <<< dotfiles 1password ssh agent <<<
EOF

chmod 600 "${SSH_CONFIG}"

if command -v 1password >/dev/null 2>&1; then
  echo "==> 1Password app detected."
else
  echo "WARN: 1Password app command not found in PATH."
fi

if [[ -S "${HOME}/.1password/agent.sock" ]]; then
  echo "==> 1Password SSH agent socket is present: ${HOME}/.1password/agent.sock"
else
  echo "INFO: 1Password SSH agent socket not found yet."
  echo "      Open 1Password desktop app and enable SSH Agent in Developer settings."
fi

echo "==> SSH config updated with global IdentityAgent in ${SSH_CONFIG}"
