#!/usr/bin/env bash
set -euo pipefail

NAS_ALIAS="${UGREEN_NAS_ALIAS:-ugreen-nas}"
NAS_IP_HOME="${UGREEN_NAS_IP_HOME:-192.168.1.110}"
NAS_IP_WORK="${UGREEN_NAS_IP_WORK:-192.168.3.91}"
MOUNT_POINT="${UGREEN_NAS_MOUNT_POINT:-/mnt/data}"

check_ip() {
  local ip="$1"
  if command -v nc >/dev/null 2>&1; then
    if timeout 2 nc -z -w 1 "$ip" 445 >/dev/null 2>&1; then
      echo "up"
    else
      echo "down"
    fi
  elif command -v ping >/dev/null 2>&1; then
    if ping -c 1 -W 1 "$ip" >/dev/null 2>&1; then
      echo "up"
    else
      echo "down"
    fi
  else
    echo "unknown"
  fi
}

home_status="$(check_ip "$NAS_IP_HOME")"
work_status="$(check_ip "$NAS_IP_WORK")"

reachable="none"
if [[ "$home_status" == "up" ]]; then
  reachable="$NAS_IP_HOME"
elif [[ "$work_status" == "up" ]]; then
  reachable="$NAS_IP_WORK"
fi

mounted="no"
mount_src=""
if findmnt -rn "$MOUNT_POINT" >/dev/null 2>&1; then
  mounted="yes"
  mount_src="$(findmnt -rn -o SOURCE "$MOUNT_POINT" 2>/dev/null || true)"
fi

automount_state="n/a"
mount_state="n/a"
if command -v systemctl >/dev/null 2>&1; then
  automount_state="$(systemctl is-active mnt-data.automount 2>/dev/null || true)"
  mount_state="$(systemctl is-active mnt-data.mount 2>/dev/null || true)"
fi

echo "NAS alias:            $NAS_ALIAS"
echo "Home IP ($NAS_IP_HOME): $home_status"
echo "Work IP ($NAS_IP_WORK): $work_status"
echo "Reachable NAS IP:      $reachable"
echo "Mount point:           $MOUNT_POINT"
echo "Mounted:               $mounted"
if [[ -n "$mount_src" ]]; then
  echo "Mount source:          $mount_src"
fi
echo "mnt-data.automount:    $automount_state"
echo "mnt-data.mount:        $mount_state"

if [[ "$mounted" == "yes" ]]; then
  echo ""
  echo "Directory preview ($MOUNT_POINT):"
  ls -1 "$MOUNT_POINT" 2>/dev/null | head -n 10 || true
fi
