#!/usr/bin/env bash
set -euo pipefail

# Wayland-native monitor configuration for Ulm office docking
# Dell WD19TB Thunderbolt Dock + 2x Dell U2415 (1920x1200)
# Layout: DP-5 (left) | DP-6 (center) | eDP-1 (right)
# Logical positions: 0 | 1920 | 3840

swaymsg output DP-5  mode 1920x1200@59.950Hz position 0    0 scale 1
swaymsg output DP-6  mode 1920x1200@59.950Hz position 1920 0 scale 1
swaymsg output eDP-1 mode 2560x1600@120Hz   position 3840 0 scale 1.5

echo "✓ Ulm office docking display profile applied"
