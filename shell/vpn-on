#!/usr/bin/env bash
set -euo pipefail

VPN_HOST="${1:-lis01.vpn.liebherr.com}"
BROWSER_CMD="${OPENCONNECT_BROWSER:-xdg-open}"

# gpclient (from yuezk/globalprotect-openconnect) is more reliable for
# some Azure AD SAML flows than raw openconnect form parsing.
if command -v gpclient >/dev/null 2>&1; then
  echo "==> Using gpclient backend for GlobalProtect SAML flow..."
  exec sudo gpclient connect "$VPN_HOST" --hip
fi

workdir="$(mktemp -d)"
trap 'rm -rf "$workdir"' EXIT

login_env="$workdir/openconnect-login.env"

echo "==> Starting SAML authentication as user (browser flow)..."
if ! openconnect \
  --protocol=gp \
  --external-browser="$BROWSER_CMD" \
  --authenticate \
  "$VPN_HOST" >"$login_env"; then
  echo "ERROR: openconnect SAML authentication failed." >&2
  echo "Hint: this tenant may require gpclient form handling." >&2
  echo "      Install yuezk COPR package and retry vpn-on:" >&2
  echo "      sudo dnf copr enable yuezk/globalprotect-openconnect" >&2
  echo "      sudo dnf install -y globalprotect-openconnect" >&2
  exit 1
fi

# Output format is shell assignments generated by openconnect.
# shellcheck source=/dev/null
source "$login_env"

if [[ -z "${COOKIE:-}" || -z "${HOST:-}" ]]; then
  echo "ERROR: openconnect did not return COOKIE/HOST from authentication flow." >&2
  exit 1
fi

echo "==> Authentication successful. Establishing VPN tunnel..."

args=(
  --protocol=gp
  --cookie-on-stdin
)

if [[ -n "${FINGERPRINT:-}" ]]; then
  args+=(--servercert "$FINGERPRINT")
fi

if [[ -n "${RESOLVE:-}" ]]; then
  args+=(--resolve "$RESOLVE")
fi

if [[ -n "${CONNECT_URL:-}" ]]; then
  target="$CONNECT_URL"
else
  target="$HOST"
fi

echo "$COOKIE" | sudo openconnect "${args[@]}" "$target"
