#!/usr/bin/env bash
# network-status-waybar: Display primary network connection with fallback to active alternatives
# Emits JSON for Waybar custom module
# Priority: Dock Ethernet (enx98e74328ea7a) > Active WiFi > Other connections > Disconnected

PRIMARY_IFACE="enx98e74328ea7a"

# Check primary Ethernet interface first
if [[ -e "/sys/class/net/$PRIMARY_IFACE" ]]; then
    ADDR=$(ip -4 addr show "$PRIMARY_IFACE" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}/\d+' | head -1)
    if [[ -n "$ADDR" ]]; then
        # Primary Ethernet is up with IP
        printf '{"text":"\\uf796  %s","tooltip":"Ethernet: %s\\n%s","class":"ethernet"}\n' "$ADDR" "$PRIMARY_IFACE" "$ADDR"
        exit 0
    fi
fi

# Primary interface down, check active connections from NetworkManager.
# Priority after primary dock NIC: other Ethernet > WiFi > other > Disconnected.
ACTIVE_CONNS=$(nmcli -t connection show --active 2>/dev/null)

# First, prefer any active non-primary Ethernet connection (e.g., laptop NIC eno1).
ALT_ETH=$(echo "$ACTIVE_CONNS" | awk -F':' -v primary="$PRIMARY_IFACE" '$3 ~ /802-3-ethernet/ && $4 != primary {print; exit}')

if [[ -n "$ALT_ETH" ]]; then
    ALT_ETH_DEV=$(echo "$ALT_ETH" | cut -d: -f4)
    ALT_ETH_IP=$(ip -4 addr show "$ALT_ETH_DEV" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}/\d+' | head -1)
    if [[ -n "$ALT_ETH_IP" ]]; then
        printf '{"text":"\\uf796  %s","tooltip":"Ethernet: %s\\n%s","class":"ethernet"}\n' "$ALT_ETH_IP" "$ALT_ETH_DEV" "$ALT_ETH_IP"
        exit 0
    fi
fi

# Next, try WiFi fallback.
WIFI_CONN=$(echo "$ACTIVE_CONNS" | awk -F':' '$3 ~ /802-11-wireless/ {print $1; exit}')

if [[ -n "$WIFI_CONN" ]]; then
    WIFI_DEV=$(echo "$ACTIVE_CONNS" | awk -F':' -v name="$WIFI_CONN" '$1 == name {print $4; exit}')

    if [[ -n "$WIFI_DEV" ]]; then
        IP_ADDR=$(ip -4 addr show "$WIFI_DEV" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}/\d+' | head -1)
        if [[ -n "$IP_ADDR" ]]; then
            printf '{"text":"\\uf1eb  %s  %s","tooltip":"WiFi: %s\\n%s","class":"wifi"}\n' "$WIFI_CONN" "$IP_ADDR" "$WIFI_CONN" "$IP_ADDR"
            exit 0
        fi
    fi
fi

# No Ethernet/WiFi fallback hit, check for other active connections (skip loopback and bridges).
ACTIVE=$(echo "$ACTIVE_CONNS" | grep -v loopback | grep -v docker0 | grep -v '^br-' | head -1)

if [[ -n "$ACTIVE" ]]; then
    # Get connection type and details
    CONN_NAME=$(echo "$ACTIVE" | cut -d: -f1)
    CONN_TYPE=$(echo "$ACTIVE" | cut -d: -f3)
    ACTIVE_DEV=$(echo "$ACTIVE" | cut -d: -f4)

    # Get IP address for the active connection
    if [[ -z "$ACTIVE_DEV" ]]; then
        ACTIVE_DEV=$(nmcli -t -f DEVICE connection show "$CONN_NAME" 2>/dev/null | head -1)
    fi

    if [[ -n "$ACTIVE_DEV" ]]; then
        IP_ADDR=$(ip -4 addr show "$ACTIVE_DEV" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}/\d+' | head -1)

        if [[ -n "$IP_ADDR" ]]; then
            case "$CONN_TYPE" in
                ethernet|802-3-ethernet)
                    printf '{"text":"\\uf796  %s","tooltip":"Ethernet: %s\\n%s","class":"ethernet"}\n' "$IP_ADDR" "$ACTIVE_DEV" "$IP_ADDR"
                    exit 0
                    ;;
                vpn)
                    printf '{"text":"\\uf023  %s  %s","tooltip":"VPN: %s\\n%s","class":"vpn"}\n' "$CONN_NAME" "$IP_ADDR" "$CONN_NAME" "$IP_ADDR"
                    exit 0
                    ;;
                *)
                    printf '{"text":"\\uf796  %s  %s","tooltip":"%s: %s\\n%s","class":"other"}\n' "$CONN_NAME" "$IP_ADDR" "$CONN_TYPE" "$CONN_NAME" "$IP_ADDR"
                    exit 0
                    ;;
            esac
        fi
    fi
fi

# No active connection found
echo "{\"text\":\"\uf127  Disconnected\",\"tooltip\":\"No active network connection\",\"class\":\"disconnected\"}"
