## Removed Alacritty-specific window rules

# Terminal scratchpad
# Sway-native terminal scratchpad using foot + title match.
for_window [app_id="foot" title="scratchpad-term"] floating enable
for_window [app_id="foot" title="scratchpad-term"] resize set 1200 800
for_window [app_id="foot" title="scratchpad-term"] mark scratchpad-term
for_window [app_id="foot" title="scratchpad-term"] move scratchpad
for_window [app_id="foot" title="scratchpad-term"] border none
bindsym $mod+Shift+t exec --no-startup-id $HOME/.config/sway/scripts/toggle-scratchpad-term.sh

# htop floating window
for_window [app_id="foot" title="htop-float"] floating enable
bindsym $mod+Shift+p exec foot --title htop-float -e htop

# qutebrowser scratchpad
for_window [app_id="qutebrowser"] floating enable
for_window [app_id="qutebrowser"] resize set 825 800
for_window [app_id="qutebrowser"] mark scratchpad-qutebrowser
for_window [app_id="qutebrowser"] move scratchpad
for_window [app_id="qutebrowser"] border none
for_window [class="qutebrowser"] floating enable
for_window [class="qutebrowser"] resize set 825 800
for_window [class="qutebrowser"] mark scratchpad-qutebrowser
for_window [class="qutebrowser"] move scratchpad
for_window [class="qutebrowser"] border none
for_window [instance="qutebrowser"] floating enable
for_window [instance="qutebrowser"] resize set 825 800
for_window [instance="qutebrowser"] mark scratchpad-qutebrowser
for_window [instance="qutebrowser"] move scratchpad
for_window [instance="qutebrowser"] border none
bindsym $mod+Shift+i exec --no-startup-id $HOME/.config/sway/scripts/toggle-scratchpad-qutebrowser.sh

# pavucontrol scratchpad
for_window [instance="pavucontrol"] floating enable
for_window [instance="pavucontrol"] resize 825 800
# move pavucontrol window to scratchpad which hides it automatically
for_window [instance="pavucontrol"] move scratchpad
for_window [instance="pavucontrol"] border none
exec --no-startup-id pavucontrol --target window
bindsym $mod+Shift+a [instance="pavucontrol"] scratchpad show ; [instance="pavucontrol"] move position center

# spotify scratchpad
