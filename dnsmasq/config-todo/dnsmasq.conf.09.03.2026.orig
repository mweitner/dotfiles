# disables DNS functionality
#port=0
port=53
enable-tftp
# concept tftp-root subfolders:
#  /root/: provides rootfs to mount by nfs
#  /images/: read only access to image to be flashed by dd
#  /boot/: boot artifacts like linux kernal fitImage, zImage, dtbs...
#  <project>/root/: project specific rootfs to mount by nfs
#  <project>/images/: project specific access to image to be flashed by dd
#  <project>/boot/: project specific boot artifacts like linux kernal fitImage,
#    zImage, dtbs...
tftp-root=/opt/netboot

# the network device on which dnsmasq operates
# First we used interface=enx0050b65ea4a2 only, but if that interface is not
# connected the dnsmasq service fails to start!
# Best solution is to use interface and bind-dynamic option
#interface=enx0050b65ea4a2 <- broken adapter when used in Lindau (LED) 12.01.2024
#interface=enx0050b65ea50f
interface=enx00e04cb828b5
listen-address=192.168.2.1
#listen-address=192.168.3.200
interface=enx54b80aefbffa
# new USB2Ethernet adapter (private adapter owned by mweitner)
interface=enx00e04c680221
# dc5 evo
interface=enx3c4937054746
# dell host pc ethernet
#interface=enxf4ee08caae80
bind-dynamic

# activate dhcp function
#dhcp-range=interface:enx0050b65ea4a2,192.168.3.10,192.168.3.100,255.255.255.0,12h
#dhcp-range=interface:enx54b80aefbffa,192.168.3.10,192.168.3.100,255.255.255.0,12h
#dhcp-range=interface:enx00e04c680221,192.168.3.110,192.168.3.120,255.255.255.0,12h
#dhcp-range=interface:enx0050b65ea50f,169.254.1.10,169.254.1.100,255.255.255.0,12h
#dhcp-range=interface:enx0050b65ea50f,192.168.3.10,192.168.3.100,255.255.255.0,12h
# new adapter: enx00e04cb828b5, setup for DC5 linux-lpo
dhcp-range=interface:enx00e04cb828b5,192.168.3.210,192.168.3.220,255.255.255.0,12h
dhcp-range=interface:enx3c4937054746,192.168.2.10,192.168.2.100,255.255.255.0,12h
#dhcp-range=interface:enx00e04cb828b5,192.168.2.10,192.168.2.100,255.255.255.0,12h

