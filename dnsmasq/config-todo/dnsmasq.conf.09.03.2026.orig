# 01, netmask
dhcp-option=interface:enx0050b65ea4a2,option:netmask,255.255.255.0
#dhcp-option=interface:enx0050b65ea50f,option:netmask,255.255.255.0
dhcp-option=interface:enx00e04cb828b5,option:netmask,255.255.255.0
dhcp-option=interface:enx00e04c680221,option:netmask,255.255.255.0
# 03, gatewayip
#dhcp-option=interface:enx0050b65ea4a2,option:router,192.168.3.1
#dhcp-option=interface:enx0050b65ea50f,option:router,192.168.3.2
#dhcp-option=interface:enx00e04cb828b5,option:router,192.168.2.1
dhcp-option=interface:enx00e04cb828b5,option:router,192.168.3.200

#dc5evo
dhcp-option=interface:enx3c4937054746,option:router,192.168.2.1
dhcp-option=interface:enx3c4937054746,option:root-path,/opt/netboot/root/imx6q-display5-evo
dhcp-boot=interface:enx3c4937054746,boot/imx8-display5-evo/fitImage,imx8-display5-evo,192.168.2.1

#dhcp-option=interface:enx00e04c680221,option:router,192.168.3.1
# 06, dnsip
#dhcp-option=interface:enx0050b65ea4a2,option:dns-server,192.168.3.1
#dhcp-option=interface:enx00e04c680221,option:dns-server,192.168.3.1
#dhcp-option=interface:enx0050b65ea50f,option:dns-server,192.168.3.2
#dhcp-option=interface:enx0050b65ea50f,option:dns-server,192.168.2.1
# LIS firewall DNS
#dhcp-option=interface:enx0050b65ea50f,option:dns-server,10.146.72.1
# IoT core DNS hack
# Required changes: port set to 53
# the address attribute works only within dev net!!!
#dhcp-option=interface:enx00e04cb828b5,option:dns-server,192.168.2.1
# Attention: for iot core only!!!
address=/lpo-dc5-v1.fota.iotdevices.liebherr.com/10.242.162.5
# 17, uboot-env: rootpath
# Important: The rootpath must point to the rootfs netboot folder.
# For example:
# - dc5 display default is /srv/tftp/DISP5/rootfs
# - dc5 local development default is /opt/netboot/root/imx6q-display5
dhcp-option=interface:enx0050b65ea4a2,option:root-path,/opt/netboot
#dhcp-option=interface:enx00e04cb828b5,option:root-path,/opt/netboot/root/imx6q-display5
dhcp-option=interface:enx00e04cb828b5,option:root-path,/opt/netboot/root/imx6qleg-mcg
#dhcp-option=interface:enx00e04c680221,option:root-path,/opt/netboot/root/imx6sleg-mcg
dhcp-option=interface:enx00e04c680221,option:root-path,/opt/netboot/root/imx6qleg-mcg
