{
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Google.geminicodeassist",
        "GoogleCloudTools.cloudcode",
        "ms-python.python"
      ]
    }
  },
  "forwardPorts": [
    45207
  ],
  "name": "Gemini Stable: Multi-Poetry Workspace",
  "postCreateCommand": "sudo /bin/bash .devcontainer/setup_poetry.sh",
  "remoteUser": "vscode",
  "settings": {
    "poetry.virtualenvs.in-project": true,
    "python.defaultInterpreterPath": "/usr/local/bin/python",
    "python.poetry.enabled": true
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}"
}
