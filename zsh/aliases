alias ll='ls -lah'
alias d='dirs -v'
for index ({1..9}) alias "$index"="cd +${index}"; unset index

alias vi='nvim'
alias vim='nvim'

#git
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --decorate --oneline --graph --all'

alias mc='EDITOR=nvim . /usr/lib/mc/mc-wrapper.sh'

alias python='python3'

function poetry-dev() {
    #first cleanup
    poetry-clean
    #than create venv and install
	poetry env use python3.10
    poetry install
    source $(poetry env info --path)/bin/activate
    # Load .env variables
    # makes sure .env is loaded even module is run with python instead of poetry run
    set -a
    [ -f .env ] && source .env
    set +a
}

function poetry-clean() {
    poetry env remove $(poetry env info --executable)
    deactivate
}

function repo-status() {
    repo forall -c '\
        echo "===";\
        basename `git rev-parse --show-toplevel`;\
        git describe --tags --dirty --always --long\
    '
}